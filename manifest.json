{
  "manifest_version": 3,
  "name": "Kalkulator by dabox",
  "version": "1.3.0",
  "description": "Inteligentny system wyceny pojazdów udostępniony użytkownikom forum ProjectRPG.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://projectrpg.pl/vehicles/*",
        "https://projectrpg.pl/vehicles/?"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data/*.json",
        "icons/*.png"
      ],
      "matches": [
        "https://projectrpg.pl/*"
      ]
    }
  ]
}
